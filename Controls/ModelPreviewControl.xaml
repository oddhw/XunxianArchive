<UserControl
    x:Class="XunxianDpkViewer.Controls.ModelPreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
    <Grid Background="{StaticResource SurfaceAltBrush}" CornerRadius="16">
        <Grid x:Name="Surface"
              Background="{StaticResource SurfaceAltBrush}"
              SizeChanged="Surface_SizeChanged"
              PointerPressed="Surface_PointerPressed"
              PointerMoved="Surface_PointerMoved"
              PointerReleased="Surface_PointerReleased"
              PointerCanceled="Surface_PointerReleased"
              PointerWheelChanged="Surface_PointerWheelChanged">
            <Image x:Name="RasterImage" Stretch="Fill" IsHitTestVisible="False" />
        </Grid>
        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="14"
                Padding="10,6"
                Background="#D0182334"
                CornerRadius="8">
            <TextBlock x:Name="HintText"
                       Text="实体预览 · 拖拽旋转 · 滚轮缩放"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       FontSize="12" />
        </Border>
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="14"
                    Orientation="Horizontal"
                    Spacing="6">
            <ToggleButton x:Name="TextureModeButton" Content="贴图" IsEnabled="False" Click="TextureModeButton_Click" />
            <ToggleButton x:Name="SolidModeButton" Content="实体" IsChecked="True" Click="SolidModeButton_Click" />
            <ToggleButton x:Name="WireframeModeButton" Content="线框" Click="WireframeModeButton_Click" />
        </StackPanel>
        <TextBlock x:Name="EmptyText"
                   Text="选择一个 PMF 模型查看实体预览"
                   Foreground="{StaticResource MutedTextBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>
