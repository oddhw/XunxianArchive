<UserControl
    x:Class="XunxianDpkViewer.Controls.ModelPreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
    <Grid Background="#07131C" CornerRadius="16">
        <Canvas x:Name="Surface"
                Background="#07131C"
                SizeChanged="Surface_SizeChanged"
                PointerPressed="Surface_PointerPressed"
                PointerMoved="Surface_PointerMoved"
                PointerReleased="Surface_PointerReleased"
                PointerCanceled="Surface_PointerReleased"
                PointerWheelChanged="Surface_PointerWheelChanged" />
        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="14"
                Padding="10,6"
                Background="#B0162530"
                CornerRadius="8">
            <TextBlock x:Name="HintText"
                       Text="实体预览 · 拖拽旋转 · 滚轮缩放"
                       Foreground="#B8D8E5"
                       FontSize="12" />
        </Border>
        <TextBlock x:Name="EmptyText"
                   Text="选择一个 PMF 模型查看实体预览"
                   Foreground="#78909C"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>
