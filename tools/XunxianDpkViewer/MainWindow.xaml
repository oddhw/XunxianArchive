<Window
    x:Class="XunxianDpkViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="寻仙 DPK 资源浏览器">

    <Grid Background="#09131A" RequestedTheme="Dark" Loaded="MainWindow_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarDragRegion" Grid.Row="0" Background="#0D1A22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="28" Height="28" Margin="14,0,10,0" CornerRadius="8" Background="#207A65">
                <FontIcon Glyph="&#xE7C3;" Foreground="White" FontSize="15" />
            </Border>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="寻仙 DPK 资源浏览器" Foreground="#F3F8FA" FontWeight="SemiBold" FontSize="14" />
                <Border Padding="7,2" CornerRadius="8" Background="#143B35">
                    <TextBlock Text="WinUI 3" Foreground="#72E5C1" FontSize="11" />
                </Border>
            </StackPanel>
            <TextBlock Grid.Column="2" x:Name="ArchiveSummaryText" Margin="0,0,16,0"
                       VerticalAlignment="Center" Foreground="#78909C" FontSize="12" />
        </Grid>

        <NavigationView x:Name="CategoryNavigation"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        IsPaneOpen="True"
                        OpenPaneLength="188"
                        CompactPaneLength="56"
                        Background="#091820"
                        Foreground="#DCE9EE"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="CategoryNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="ImageNavigationItem" Content="图标与贴图" Tag="image" IsSelected="True" Foreground="#DCE9EE">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xEB9F;" Foreground="#9FD8CB" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="声音" Tag="sound" Foreground="#DCE9EE">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8D6;" Foreground="#9FD8CB" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="ModelNavigationItem" Content="模型" Tag="model" Foreground="#DCE9EE">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE809;" Foreground="#9FD8CB" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.Content>
                <Grid Padding="20,14,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="PageTitleText" Text="图标与贴图" FontSize="28" FontWeight="SemiBold" Foreground="#F2F7F8" />
                            <TextBlock x:Name="PageDescriptionText" Text="浏览 GUI 图标、装备图和场景贴图" Margin="0,3,0,0" Foreground="#91A7B3" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Click="OpenFolderButton_Click" ToolTipService.ToolTip="选择包含 DPK 的 res 目录">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                    <TextBlock Text="打开资源目录" />
                                </StackPanel>
                            </Button>
                            <Button Click="OpenArchiveButton_Click" ToolTipService.ToolTip="打开单个 DPK 文件">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                                    <TextBlock Text="打开 DPK" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="BatchExportButton" Click="BatchExportButton_Click" IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <FontIcon Glyph="&#xE896;" FontSize="14" />
                                    <TextBlock Text="导出查询结果" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,18,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox x:Name="SearchBox"
                                        PlaceholderText="搜索文件名或资源路径"
                                        TextChanged="SearchBox_TextChanged" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="10">
                            <ProgressRing x:Name="BusyRing" Width="18" Height="18" IsActive="False" />
                            <TextBlock x:Name="StatusText" Foreground="#91A7B3" Text="等待载入资源" />
                            <TextBlock x:Name="CurrentPathText" Foreground="#58717D" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="420" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="PreviousPageButton" Click="PreviousPageButton_Click" IsEnabled="False" ToolTipService.ToolTip="上一页">
                                <FontIcon Glyph="&#xE76B;" />
                            </Button>
                            <Border MinWidth="96" Padding="12,7" Background="#12232C" CornerRadius="8">
                                <TextBlock x:Name="PageIndicatorText" Text="0 / 0" TextAlignment="Center" Foreground="#C4D4DC" />
                            </Border>
                            <Button x:Name="NextPageButton" Click="NextPageButton_Click" IsEnabled="False" ToolTipService.ToolTip="下一页">
                                <FontIcon Glyph="&#xE76C;" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="WorkspaceGrid" Grid.Row="2" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="AssetListColumn" Width="1.35*" MinWidth="340" />
                            <ColumnDefinition x:Name="PreviewColumn" Width="1*" MinWidth="360" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="AssetBrowserPanel" Background="#0D1A22" BorderBrush="#1E3440" BorderThickness="1" CornerRadius="16" Padding="10">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="230" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Background="#091820" BorderBrush="#182E39" BorderThickness="1" CornerRadius="12" Padding="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Margin="8,6,8,8" Spacing="3">
                                            <TextBlock Text="DPK 目录" Foreground="#DDE9ED" FontWeight="SemiBold" />
                                            <TextBlock Text="按包内真实路径浏览" Foreground="#6F8995" FontSize="10" />
                                        </StackPanel>
                                        <TreeView x:Name="FolderTree"
                                                  Grid.Row="1"
                                                  SelectionMode="Single"
                                                  SelectionChanged="FolderTree_SelectionChanged" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Background="#10232C" CornerRadius="9" Padding="12,8" Margin="0,0,0,8">
                                        <TextBlock x:Name="CurrentFolderText"
                                                   Text="尚未选择目录"
                                                   Foreground="#9FB5BF"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <Grid Grid.Row="1">
                                <GridView x:Name="ImageGrid"
                                          SelectionChanged="Asset_SelectionChanged"
                                          SelectionMode="Single">
                                    <GridView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </GridView.ItemsPanel>
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="154" Height="178" Margin="4" Padding="10"
                                                    AutomationProperties.Name="{Binding Name}"
                                                    Background="#10232C" BorderBrush="#1F3A46" BorderThickness="1" CornerRadius="12">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="120" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Border Background="#09151C" CornerRadius="9">
                                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="8" />
                                                    </Border>
                                                    <StackPanel Grid.Row="1" Margin="1,8,1,0">
                                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" Foreground="#E9F1F4" FontSize="12" />
                                                        <TextBlock Text="{Binding ArchiveName}" TextTrimming="CharacterEllipsis" Foreground="#708995" FontSize="10" Margin="0,3,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>

                                <ListView x:Name="AssetList"
                                          Visibility="Collapsed"
                                          SelectionChanged="Asset_SelectionChanged"
                                          SelectionMode="Single">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="64" Padding="8,5" ColumnSpacing="12"
                                                  AutomationProperties.Name="{Binding Name}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="42" Height="42" CornerRadius="11" Background="#153E3A">
                                                    <FontIcon Glyph="{Binding Glyph}" Foreground="#72E5C1" FontSize="18" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E9F1F4" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Path}" Foreground="#708995" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                                </StackPanel>
                                                <Border Grid.Column="2" Padding="8,3" CornerRadius="8" Background="#112A34" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ArchiveName}" Foreground="#8FAAB6" FontSize="10" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel x:Name="EmptyPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                    <FontIcon Glyph="&#xE721;" FontSize="38" Foreground="#49616D" />
                                    <TextBlock Text="当前文件夹没有匹配资源" Foreground="#78909C" />
                                </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="#0D1A22" BorderBrush="#1E3440" BorderThickness="1" CornerRadius="16" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid x:Name="PreviewHost">
                                    <Grid x:Name="ImagePreviewPanel">
                                        <Border Background="#07131A" CornerRadius="14">
                                            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="18" />
                                        </Border>
                                    </Grid>
                                    <Grid x:Name="SoundPreviewPanel" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border Background="#07131A" CornerRadius="14">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                                                <Border Width="104" Height="104" CornerRadius="52" Background="#153E3A">
                                                    <FontIcon Glyph="&#xE8D6;" FontSize="44" Foreground="#72E5C1" />
                                                </Border>
                                                <TextBlock x:Name="SoundNameText" Text="选择声音文件" Foreground="#DCE9EE" FontSize="18" TextAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <ContentControl x:Name="AudioPlayerHost" Grid.Row="1" Margin="0,12,0,0" />
                                    </Grid>
                                    <ContentControl x:Name="ModelPreviewHost"
                                                    Visibility="Collapsed"
                                                    HorizontalContentAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch" />
                                </Grid>

                                <StackPanel Grid.Row="1" Margin="2,16,2,2" Spacing="8">
                                    <TextBlock x:Name="SelectedNameText" Text="尚未选择资源" Foreground="#EEF5F7" FontWeight="SemiBold" FontSize="16" TextWrapping="Wrap" />
                                    <TextBlock x:Name="SelectedPathText" Text="从左侧选择图标、声音或模型" Foreground="#78909C" FontSize="11" TextWrapping="Wrap" MaxHeight="48" />
                                    <TextBlock x:Name="SelectedMetadataText" Foreground="#72A6A0" FontSize="11" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <Button x:Name="ExportSelectedButton" Click="ExportSelectedButton_Click" IsEnabled="False">
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <FontIcon Glyph="&#xE896;" FontSize="14" />
                                                <TextBlock Text="导出原始资源" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ExportModelButton" Click="ExportModelButton_Click" IsEnabled="False" Visibility="Collapsed">
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <FontIcon Glyph="&#xE74C;" FontSize="14" />
                                                <TextBlock Text="导出 OBJ 模型" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ExpandModelButton" Click="ExpandModelButton_Click" Visibility="Collapsed">
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <FontIcon Glyph="&#xE740;" FontSize="14" />
                                                <TextBlock x:Name="ExpandModelButtonText" Text="放大模型预览" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </NavigationView.Content>
        </NavigationView>

        <Border x:Name="PathSetupPanel"
                Grid.Row="1"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="520"
                Padding="34"
                Background="#F0182831"
                BorderBrush="#355663"
                BorderThickness="1"
                CornerRadius="20">
            <StackPanel Spacing="14" HorizontalAlignment="Stretch">
                <Border Width="64" Height="64" CornerRadius="18" Background="#153E3A" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE8B7;" FontSize="28" Foreground="#72E5C1" />
                </Border>
                <TextBlock Text="先选择《新寻仙》客户端目录" FontSize="22" FontWeight="SemiBold" Foreground="#F2F7F8" TextAlignment="Center" />
                <TextBlock Text="可以选择游戏安装目录，也可以直接选择 res 目录。程序会记住这个位置，换电脑后首次启动会重新提示。"
                           Foreground="#91A7B3" TextWrapping="Wrap" TextAlignment="Center" />
                <Button Content="选择客户端目录" Click="ChooseInitialPathButton_Click" HorizontalAlignment="Center" Padding="22,10" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
